#!/usr/bin/env python3
"""Forensic Toolkit — ftk 命令行入口 (零外部依赖)"""
import sys
from pathlib import Path

_SCRIPT_DIR = Path(__file__).resolve().parent           # bin/
_PROJECT_ROOT = _SCRIPT_DIR.parent                      # project root (contains forensic_toolkit/ package)
_PACKAGE = _PROJECT_ROOT / "forensic_toolkit"            # the inner package dir

if _PACKAGE.exists() and str(_PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(_PROJECT_ROOT))

# Check for 'gui' subcommand
if len(sys.argv) > 1 and sys.argv[1] == "gui":
    from forensic_toolkit.gui.app import run_gui
    run_gui()
else:
    from forensic_toolkit.cli.main import cli
    cli()
